FEISHU_CLIENT_ID=
FEISHU_CLIENT_SECRET=

# docker compose 中 qa_service 使用（本地复制为 infra/.env）
BOOKSTACK_TOKEN_ID=
BOOKSTACK_TOKEN_SECRET=
ANTHROPIC_API_KEY=
# 嵌入向量（可选）：不配则 RAG 只用 BookStack 搜索，不做本地向量索引
# 硅基流动示例：EMBEDDING_BASE_URL=https://api.siliconflow.cn/v1  EMBEDDING_API_KEY=sk-...
EMBEDDING_BASE_URL=
EMBEDDING_API_KEY=
# 硅基流动推荐；OpenAI 官方可改为 text-embedding-3-small
OPENAI_EMBEDDING_MODEL=Qwen/Qwen3-Embedding-8B

# 仍兼容 OpenAI 官方：只配 OPENAI_API_KEY 即可
OPENAI_API_KEY=
OPENAI_BASE_URL=

# 文档入库 /api/ingest（与 web「上传文档」联动）
# INGEST_MAX_FILE_MB=50
# INGEST_OCR=true
# INGEST_EXTRACT_HOOK=