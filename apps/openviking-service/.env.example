# OpenViking sidecar 环境变量样例
# 复制为 infra/.env（仓库根的 infra/.env 已经存在则追加这几行即可）
# 真正的 secret 不要提交，docker-compose 会通过 ${VAR:-default} 读取

# 总开关：本机调试时显式置为 1 才会启用 viking 集成
VIKING_ENABLED=0

# qa-service 调用 viking 的地址
# 容器内 = http://openviking:1933  ；本机 dev = http://localhost:1933
VIKING_BASE_URL=http://openviking:1933

# OpenViking 自身需要的密钥（留空走 dev 无认证模式）
VIKING_ROOT_KEY=

# 复用硅基 Qwen（默认值在 entrypoint.sh）
# 如要 override，取消注释
# OPENAI_BASE_URL=https://api.siliconflow.cn/v1
# OPENAI_API_KEY=${EMBEDDING_API_KEY}
# OPENAI_MODEL=Qwen/Qwen2.5-72B-Instruct
# OPENAI_EMBEDDING_MODEL=Qwen/Qwen3-Embedding-8B

# qa-service 端的软超时（毫秒）
VIKING_RECALL_TIMEOUT_MS=200
VIKING_SAVE_TIMEOUT_MS=1000
