# 本机直接跑 qa-service 时用浏览器可访问的 BookStack 地址；docker compose 内会被覆盖为 http://bookstack
# 宿主端口取自 infra/docker-compose.yml 中 bookstack 的 ports「16875:80」
BOOKSTACK_URL=http://localhost:16875
# 启动 BookStack 后到 /settings/users/<id>/create-api-token 创建一个 token，把 ID + Secret 填进来
BOOKSTACK_TOKEN_ID=<your-bookstack-token-id>
BOOKSTACK_TOKEN_SECRET=<your-bookstack-token-secret>

# 向量索引（可选）：不配则 RAG 仅用 BookStack 搜索
# 硅基流动：EMBEDDING_BASE_URL=https://api.siliconflow.cn/v1  EMBEDDING_API_KEY=sk-...
EMBEDDING_BASE_URL=https://api.siliconflow.cn/v1
EMBEDDING_API_KEY=sk-<your-siliconflow-api-key>
# 与 EMBEDDING_API_KEY 二选一（硅基流动常用此名）
SILICONFLOW_API_KEY=sk-<your-siliconflow-api-key>
OPENAI_API_KEY=
OPENAI_BASE_URL=
# 硅基流动推荐；仅用 OpenAI 官方时改为 text-embedding-3-small 等
OPENAI_EMBEDDING_MODEL=Qwen/Qwen3-Embedding-8B

DB_HOST=127.0.0.1
# 与 infra/docker-compose.yml 中 bookstack_db 的 ports「13307:3306」一致
DB_PORT=13307
DB_NAME=bookstack
DB_USER=bookstack
DB_PASS=bookstack_secret

# ─── Postgres (pgvector) ────────────────────────────────────────────
# 与 infra/docker-compose.yml 中 pg_db 的 ports「25432:5432」一致
PG_HOST=127.0.0.1
PG_PORT=25432
PG_DB=knowledge
PG_USER=knowledge
PG_PASS=knowledge_secret

# ─── Apache AGE (知识图谱 sidecar) ──────────────────────────────────
# 与 infra/docker-compose.yml 中 kg_db 的 ports「15433:5432」一致
# KG_ENABLED=0 关闭则知识图谱 / 图洞察 API 返回 503，不影响其他功能
KG_HOST=127.0.0.1
KG_PORT=15433
KG_DB=kg
KG_USER=kg
KG_PASS=kg_secret
KG_GRAPH=knowledge
KG_ENABLED=1

# ─── Unified Auth Gateway (二选一；生产环境必填；本地开发可全部留空走 DEV BYPASS) ───
# 方式 A：JWKS（BookStack OIDC / Keycloak / Auth0 等）
# AUTH_JWKS_URL=http://localhost:6875/.well-known/jwks.json
# 方式 B：HS256 对称密钥（独立签发）
# AUTH_HS256_SECRET=change-me
# NODE_ENV=production 且两者均为空 → 启动会 fail-fast 退出

# 文档入库 /api/ingest（方案 B：服务端抽正文）
# INGEST_MAX_FILE_MB=50
# INGEST_OCR=true
# OCR 引擎：builtin（默认，officeparser 内置）/ tesseract（需另装 tesseract.js）
# INGEST_OCR_ENGINE=tesseract
# OCR 语言：tesseract.js 用，默认 chi_sim+eng
# OCR_LANGS=chi_sim+eng

# ─── PDF Pipeline v2 (opendataloader-pdf + 可选 VLM) ─────────────────
# 需要 JDK 11+。本机 brew install openjdk@21 ；Docker 镜像已含 openjdk-17-jre-headless
# 缺 java 时自动降级到旧 PDFParse v2 路径
# VLM（图意描述）开关；关时只做结构化抽取
# INGEST_VLM_ENABLED=true
# VLM 模型；默认硅基 Qwen2.5-VL-72B-Instruct，复用 EMBEDDING_API_KEY
# INGEST_VLM_MODEL=Qwen/Qwen2.5-VL-72B-Instruct
# 图片落档根目录（相对仓库根；默认 infra/asset_images）
# ASSET_IMAGE_ROOT=infra/asset_images
#
# .md / .txt 使用 Text Preprocess Skill（需本机 python3 与 apps/skill/text-preprocess-skill 依赖）
# INGEST_USE_TEXT_SKILL=true
# TEXT_SKILL_PYTHON=python3
# TEXT_PREPROCESS_SKILL_ROOT=  （默认：qa-service 上一级的 apps/skill/text-preprocess-skill）
# TEXT_SKILL_INGEST_CONFIG=    （默认：qa-service/config/text-skill-ingest.yaml，无 LLM）
# 上传成功后前端调用 POST /api/asset-directory/register-bookstack-page（与资产目录同路由；亦保留 /api/ingest/register-indexed-page 兼容）
# 外挂自定义提取（绝对路径 .mjs/.ts 等，ESM）：返回 { kind:'text', text } | { kind:'attachment_only', hint } | null
# INGEST_EXTRACT_HOOK=

# 资产目录 API：/api/asset-directory（与 DB_* 同库，表 asset_source / asset_item / asset_knowledge_link）
# 写操作（同步、刷新映射、摘要）可传请求头 x-asset-role: viewer 将返回 403；省略或为 admin 则允许写入
# 问答里「数据管理员」分支（@数据管理员 / #资产）需配置 ANTHROPIC_API_KEY

# ─── ingest-async-pipeline（2026-04-24） ─────────────────────────────────────
# 异步 ingest 状态机；关闭则所有入口走同步路径（行为等同老版本）
# INGEST_ASYNC_ENABLED=true
# body ≤ 阈值自动走同步，避免小文件排队延迟；单位字节，默认 2 MiB
# INGEST_ASYNC_THRESHOLD_BYTES=2097152
# Worker 并发上限与轮询间隔
# INGEST_WORKER_CONCURRENCY=2
# INGEST_WORKER_INTERVAL_MS=500
# SIGTERM 后等 in_progress job 完成的最长毫秒；超时强制回滚为 queued
# INGEST_WORKER_SHUTDOWN_GRACE_MS=30000

# ─── graph-insights（2026-04-24） ───────────────────────────────────────────
# 图谱洞察：孤立页面 / 桥接节点 / 惊奇连接 / 稀疏社区 + 一键 Deep Research
# 关闭则 /api/insights 返回 503 FEATURE_DISABLED
# GRAPH_INSIGHTS_ENABLED=true
# 缓存 TTL（秒），默认 30min；签名不匹配会先于 TTL 触发重算
# GRAPH_INSIGHTS_TTL_SEC=1800
# Louvain resolution；1.0 = graphology 默认；调大社区更少更大，调小更多更小
# GRAPH_INSIGHTS_LOUVAIN_RESOLUTION=1.0
# 边数超限则跳过 Louvain，降级为 isolated + HAS_TAG-based bridges（payload degraded=true）
# GRAPH_INSIGHTS_MAX_EDGES=10000
# 惊奇连接返回的 top-N
# GRAPH_INSIGHTS_TOP_SURPRISES=10
# 复合惊奇度权重：w_cross * cross_community + w_type * cross_type + w_weight * log(1+edge_weight)
# GRAPH_INSIGHTS_WEIGHT_CROSS_COMMUNITY=3.0
# GRAPH_INSIGHTS_WEIGHT_CROSS_TYPE=1.5
# GRAPH_INSIGHTS_WEIGHT_EDGE_LOG=1.0
# Deep Research 研究主题生成的模型；空则复用 LLM_MODEL（rag 同模型）
# GRAPH_INSIGHTS_TOPIC_MODEL=
# 孤立页面最小资产年龄（天）；避免新 ingest 资产被误判
# GRAPH_INSIGHTS_ISOLATED_MIN_AGE_DAYS=7
# 稀疏社区内聚度阈值；cohesion < 阈值即视为稀疏
# GRAPH_INSIGHTS_SPARSE_COHESION_THRESHOLD=0.15
# 稀疏社区最小成员数；过小社区不报
# GRAPH_INSIGHTS_SPARSE_MIN_SIZE=3

# ─── knowledge-graph-view（2026-04-25） ─────────────────────────────────────
# 全 Space 力导向图视图：sigma.js + ForceAtlas2
# 节点上限（按 degree 降序截断）；超限 payload.truncated=true
# KG_GRAPH_MAX_NODES=800
# 边上限（CO_CITED 优先，HAS_TAG 劣后；按 weight 降序截断）
# KG_GRAPH_MAX_EDGES=3000
# 前端 ForceAtlas2 迭代次数（v1 仅供日志参考；前端硬编码 100）
# KG_GRAPH_FORCE_ATLAS_ITER=100

# ─── follow-up condensation（指代/短问题改写） ──────────────────────────────
# 进 retrieval 之前用 fast LLM 把 "把原文发我" / "解释一下" / "它是谁写的"
# 这种短指代型 follow-up 拼上最近几轮 history 改写成自洽问句，再做 embedding。
# 改写后的 query 仅用于 retrieval / grade / step_back-hyde；generateAnswer
# 仍喂用户原句 + 完整 history。失败 / 不触发 → 透明回落原句，不阻塞。
# 默认 on；=false / 0 / off / no 关闭
# RAG_CONDENSE_QUESTION_ENABLED=true

# ─── 答案意图分流（ADR-46 D-002）──────────────────────────────────────────
# 在 generateAnswer 选 prompt 之前，用 fast LLM 先把"用户问题 × 召回文档形态"
# 分到 5 类意图（factual_lookup / language_op / multi_doc_compare /
# kb_meta / out_of_scope），按意图选不同的 system prompt 模板，每个模板短而
# 专一。替代之前一份 monolithic prompt 扛所有场景的做法。
# 任何分类失败回落 factual_lookup（=老严格 RAG 行为）。
# 默认 on；=false / 0 / off / no 关闭（回落 factual_lookup）。
# B_HANDLER_ROUTING_ENABLED=true

# ─── ingest-l0-abstract（ADR-32 候选 · 2026-04-26） ──────────────────────────
# Agent 上下文 L0/L1 分级摘要 + RAG L0 粗筛
# 三档 flag 互不依赖：generate / filter / lazy 各自独立
# 全关 + chunk_abstract 表保留 = 行为字节级 baseline
#
# ingest 阶段是否生成 L0/L1（默认 on）。关掉后整段 no-op
# L0_GENERATE_ENABLED=true
# 单批 LLM 并发上限
# L0_GENERATE_CONCURRENCY=4
# chunk 短于此跳过（不值得 L0）
# L0_GENERATE_MIN_CHARS=60
#
# RAG 阶段是否启用 L0 粗筛（默认 off，eval 通过才打开）
# L0_FILTER_ENABLED=false
# 粗筛保留多少个 candidate asset 进入 retrieveInitial
# L0_FILTER_TOP_ASSETS=50
#
# rerank 后是否后台入队补 L0（默认 off）
# L0_LAZY_BACKFILL_ENABLED=false

# ─── ADR-35（2026-04-26）：QA 联网检索 + 多模态附件 ─────────────────────────
# 联网检索 provider：tavily | bing | none（默认 none = 不启用）
# WEB_SEARCH_PROVIDER=tavily
# Tavily key：https://tavily.com（1000/月免费）
# TAVILY_API_KEY=tvly-xxxxxxxxxxxxxxxxxx
# Bing 备选：Azure Cognitive Services Bing v7
# BING_API_KEY=
# BING_MARKET=zh-CN
# 软超时 / 默认 top-k
# WEB_SEARCH_TIMEOUT_MS=5000
# WEB_SEARCH_DEFAULT_TOP_K=5
#
# 多模态：图片附件走 INGEST_VLM_MODEL（已存在），默认 Qwen/Qwen2.5-VL-72B-Instruct
# 复用 EMBEDDING_API_KEY（硅基流动），无需额外 secret
